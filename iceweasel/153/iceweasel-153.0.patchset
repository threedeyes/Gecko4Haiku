@@ -2,7 +2,7 @@
  * License, v. 2.0. If a copy of the MPL was not distributed with this file,
  * You can obtain one at http://mozilla.org/MPL/2.0/. */
 
-#if defined(BSD) || defined(DARWIN)
+#if defined(BSD) || defined(DARWIN) || defined(__HAIKU__)
 #include "addrs-bsd.h"
 #include <csi_platform.h>
 #include <assert.h>
@@ -18,11 +18,38 @@
 #include <sys/ioctl.h>
 #include <errno.h>
 #include <netinet/in.h>
+#ifndef __HAIKU__
 #include <netinet6/in6_var.h>
+#endif
+
+// Haiku does not provide these IPv6 interface flags. Define them as 0
+// so the code compiles and skips the flag checks gracefully.
+#ifndef IN6_IFF_ANYCAST
+#define IN6_IFF_ANYCAST 0
+#endif
+#ifndef IN6_IFF_TENTATIVE
+#define IN6_IFF_TENTATIVE 0
+#endif
+#ifndef IN6_IFF_DUPLICATED
+#define IN6_IFF_DUPLICATED 0
+#endif
+#ifndef IN6_IFF_DETACHED
+#define IN6_IFF_DETACHED 0
+#endif
+#ifndef IN6_IFF_DEPRECATED
+#define IN6_IFF_DEPRECATED 0
+#endif
+#ifndef IN6_IFF_TEMPORARY
+#define IN6_IFF_TEMPORARY 0
+#endif
 
 static int
 stun_ifaddr_get_v6_flags(struct ifaddrs *ifaddr)
 {
+#ifdef __HAIKU__
+  // Haiku's network stack does not support fetching IPv6 flags via this ioctl.
+  return 0;
+#else
   if (ifaddr->ifa_addr->sa_family != AF_INET6) {
     return 0;
   }
@@ -48,6 +75,7 @@ stun_ifaddr_get_v6_flags(struct ifaddrs *ifaddr)
   }
   close(s);
   return flags;
+#endif
 }
 
 static int
